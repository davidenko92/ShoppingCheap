# Copia este fichero como .env y rellena tus claves
# cp .env.example .env

# Proveedor LLM: "anthropic" o "openai"
LLM_PROVIDER=anthropic

# API Keys (pon solo la del proveedor que uses)
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# Modelo a usar
# Anthropic: claude-3-5-haiku-20241022  (rapido y barato)
# OpenAI:    gpt-4o-mini                (rapido y barato)
LLM_MODEL=claude-3-5-haiku-20241022

# Umbral de confianza para el matching (0.0 - 1.0)
# Sube si hay demasiados falsos positivos
MATCHING_CONFIDENCE=0.85
